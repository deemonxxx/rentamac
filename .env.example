# RentaMac Backend Configuration
# Copy this file to .env and fill in the values

# --- Database ---
DATABASE_URL=postgresql+asyncpg://rentamac:rentamac@db:5432/rentamac

# --- WireGuard Gateway ---
GATEWAY_IP=89.125.30.138
GATEWAY_WG_PORT=51820
GATEWAY_WG_PUBLIC_KEY=

# --- macOS Node Access ---
MAC_ADMIN_USER=admin
MAC_SSH_KEY_PATH=/root/.ssh/id_ed25519

# --- YooKassa ---
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- Crypto ---
CRYPTO_WALLET_BTC=
CRYPTO_WALLET_USDT_TRC20=
CRYPTO_WALLET_USDT_ERC20=
CRYPTO_WALLET_ETH=
NOWPAYMENTS_API_KEY=

# --- CORS ---
CORS_ORIGINS=https://rentamac.ru,https://www.rentamac.ru,https://rentamac.pro,https://www.rentamac.pro,http://localhost:3000

# --- Security ---
SECRET_KEY=change-me-in-production
